                                                        <Label fx:id="infoemail" alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="48.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #ea580c; -fx-border-radius: 14;" textFill="#0f172a" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                        <Label text="Password" textFill="#0f172a" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                                        <HBox alignment="CENTER_LEFT" spacing="16.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                                            <children>
                                                                <Label fx:id="infopassword" alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="48.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #ea580c; -fx-border-radius: 14;" textFill="#0f172a" HBox.hgrow="ALWAYS" />
                                                                <CheckBox fx:id="passshow" mnemonicParsing="false" text="show" textFill="#0f172a" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                    <columnConstraints>
                                                        <ColumnConstraints minWidth="120.0" prefWidth="140.0" />
