                <Button mnemonicParsing="false" onAction="#openSellItem" prefHeight="38.0" prefWidth="104.0" style="-fx-background-color: transparent; -fx-border-color: #ea580c; -fx-border-radius: 14; -fx-background-radius: 14; -fx-text-fill: #ea580c; -fx-font-weight: bold;" text="Sell item" />
